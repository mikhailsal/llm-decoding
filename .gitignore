# Secrets / local config -- NEVER commit API keys
config.toml
.env
.env.local
*.secret

# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/
.mypy_cache/
.ruff_cache/
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml

# Local data / model caches (should live in a bulk cache dir, never committed)
models/
cache/
*.gguf
*.safetensors
*.bin

# Saved decoding transcripts / scratch output
sessions/
out/
scratch/

# Editor / OS
.idea/
.vscode/
.DS_Store

# Local agent / planning scratch (never committed)
.cursor/
plans/

# Frontend (SvelteKit) build artifacts -- the build/ directory is the
# adapter-static output we serve from `dsbx web --frontend-dist`. It's
# regenerated on every `make web-build` so no point committing it.
frontend/node_modules/
frontend/.svelte-kit/
frontend/build/
frontend/dist/
frontend/.vite/
